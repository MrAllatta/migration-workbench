DJANGO_DEBUG=1
DJANGO_SECRET_KEY=replace-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Production: set to your app hostnames (must match manifest secrets / Fly).
# CSRF_TRUSTED_ORIGINS=https://your-app.fly.dev,https://example.com

DB_ENGINE=sqlite
# Relative paths are resolved under the project root; use an absolute path in production
# (e.g. /data/db.sqlite3) to match deploy/spaces.yml storage.sqlite_path.
SQLITE_PATH=db.sqlite3

# DB_ENGINE=postgres
# DB_NAME=migration_workbench
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=localhost
# DB_PORT=5432

GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Coda API (profiling / pull_bundle when provider is coda). Never commit real tokens.
# CODA_API_TOKEN=
